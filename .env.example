# 이 파일을 .env 로 복사하고 값을 채우세요. .env 는 .gitignore 됩니다.
#   cp .env.example .env

# ====== 백엔드 선택 ======
# 1) OpenAI (기본) — 키만 채우면 끝.
OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini

# 2) Ollama 로컬 — 위 OPENAI_API_KEY 는 비워두고, 아래 두 줄의 주석을 풀어 사용.
# LLM_BASE_URL=http://localhost:11434/v1/chat/completions
# LLM_MODEL=gemma3:4b

# 3) 다른 OpenAI 호환 엔드포인트 (vLLM, LM Studio, Together 등) — URL/모델/키 자유롭게.
# LLM_BASE_URL=https://api.together.xyz/v1/chat/completions
# OPENAI_API_KEY=tg-...
# LLM_MODEL=meta-llama/Llama-3.1-8B-Instruct-Turbo
