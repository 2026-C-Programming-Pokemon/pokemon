# 이 파일을 .env 로 복사하고 값을 채우세요. .env 는 .gitignore 됩니다.
#   cp .env.example .env
#
# 게임 클라이언트는 평문 HTTP 만 지원합니다 (HTTPS/TLS 미지원).
# 따라서 LLM_BASE_URL 은 항상 http:// 여야 합니다.

# ====== 백엔드 선택 ======

# 1) app/ 보안 프록시 경유 (권장) — 업스트림 키를 클라이언트에 안 넣음.
#    POKEMON_CLIENT_SECRET 이 설정되면 자동으로 프록시 모드(HMAC 서명)가 켜집니다.
#    통신 규격: docs/proxy-protocol.md
LLM_BASE_URL=http://127.0.0.1:8080/v1/chat/completions
POKEMON_CLIENT_SECRET=<프록시의 POKEMON_CLIENT_SECRET 과 동일한 값>
# POKEMON_CLIENT_ID=pokemon-c-client/1.0
# LLM_MODEL=gpt-4o-mini
#
#    외부 서버의 프록시를 쓸 때는 그 앞단에 nginx/Caddy 를 두어 TLS 를 종단하고,
#    이 클라이언트는 LAN 내부 http 주소로 접근하게 하세요.

# 2) Ollama 로컬 직결 — 프록시 없이 로컬 모델을 직접. (POKEMON_CLIENT_SECRET 는 비움)
# LLM_BASE_URL=http://localhost:11434/v1/chat/completions
# LLM_MODEL=gemma3:4b

# 3) 그 외 OpenAI 호환 평문 HTTP 엔드포인트 (vLLM, LM Studio 등) 직결.
#    Authorization 이 필요하면 OPENAI_API_KEY 를 채웁니다.
# LLM_BASE_URL=http://localhost:8000/v1/chat/completions
# OPENAI_API_KEY=
# LLM_MODEL=...
