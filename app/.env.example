# 이 파일을 app/.env 로 복사하고 값을 채우세요.
# 절대 커밋 금지 (.gitignore 가 .env 를 차단합니다).
# 모든 값을 비워두면 ARM 서버에서도 즉시 부팅은 되지만, UPSTREAM_API_KEY 와
# POKEMON_CLIENT_SECRET 이 비어있으면 모든 요청이 거절됩니다.

# ===== 업스트림 (OpenAI 호환) =====
UPSTREAM_API_KEY=sk-...
UPSTREAM_BASE_URL=https://api.openai.com/v1
UPSTREAM_TIMEOUT_S=60

# ===== 바인딩 =====
PROXY_BIND_HOST=0.0.0.0
PROXY_BIND_PORT=8080

# ===== 인바운드 인증 (HMAC) =====
# `openssl rand -hex 32` 로 한 번 만들고, 배포 시 클라이언트와 안전히 공유.
# 공개 분산되는 게임 클라이언트라면 이 값은 결국 어딘가에서 추출될 수 있으니
# 절대적인 비밀이 아니라, "정상 클라이언트가 만든 요청을 알아보기 위한 키" 정도로 본다.
POKEMON_CLIENT_SECRET=

# 타임스탬프 freshness (초). 작을수록 강하지만 시계 오차 / 네트워크 지연을 견뎌야 함.
REQUEST_FRESHNESS_WINDOW_S=60

# nonce 캐시 TTL (초). freshness 보다 충분히 큰 값을 권장.
NONCE_CACHE_TTL_S=300

# 본문 최대 바이트.
MAX_BODY_BYTES=65536

# ===== 레이트리밋 (sliding 1분 window) =====
RATE_LIMIT_PER_IP_PER_MIN=30
RATE_LIMIT_PER_CLIENT_PER_MIN=60
RATE_LIMIT_BURST=10

# ===== 옵션 화이트리스트 =====
# 쉼표 구분. 비워두면 미적용.
ALLOWED_MODELS=
ALLOWED_CLIENT_IDS=
# User-Agent 접두사 매치 (옵션). 비워두면 미적용.
EXPECTED_USER_AGENT_PREFIX=pokemon-c-client
# nginx/Caddy 같은 신뢰 가능한 리버스 프록시 뒤일 때만 true.
# 직접 인터넷에 노출하면 false 유지.
TRUST_X_FORWARDED_FOR=false

# ===== 통신 규격 (docs/proxy-protocol.md) =====
# 클라이언트가 보내는 X-Pokemon-Protocol 헤더와 일치해야 함.
EXPECTED_PROTOCOL_VERSION=1
# 프로토콜 버전 헤더 강제. 규격 외 클라이언트를 서명 검증 전에 거른다.
REQUIRE_PROTOCOL_HEADER=true
# 본문 엄격 스키마 검증. 허용 필드(model/messages/max_tokens/temperature/stream)
# 외의 키나 잘못된 타입을 업스트림 호출 전에 거절한다.
STRICT_BODY_SCHEMA=true
# max_tokens 상한. 비용 폭주를 막는다.
MAX_COMPLETION_TOKENS=1024
# messages 배열 최대 길이.
MAX_MESSAGES=16

# ===== 기타 =====
LOG_LEVEL=INFO
REQUIRE_SIGNATURE=true
